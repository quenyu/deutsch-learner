# Backend
APP_PORT=8080
POSTGRES_DSN=postgres://postgres:postgres@localhost:5432/deutsch_learner?sslmode=disable
REDIS_ADDR=localhost:6379
HTTP_READ_TIMEOUT=10s
HTTP_READ_HEADER_TIMEOUT=5s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=10s
HTTP_HANDLER_TIMEOUT=8s
HTTP_SLOW_REQUEST_THRESHOLD=600ms
HTTP_READINESS_TIMEOUT=2s
HTTP_MAX_HEADER_BYTES=1048576
HTTP_MAX_BODY_BYTES=1048576
HTTP_MAX_CONCURRENT_REQUESTS=200
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_WINDOW=120
RATE_LIMIT_WINDOW=1m

# Frontend
PUBLIC_API_BASE_URL=http://localhost:8080
